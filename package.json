{
  "name": "health-competition-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/mobile_3",
    "apps/web_2",
    "backends/nestjs-fitbattle",
    "packages/shared",
    "packages/ui",
    "packages/step-tracker"
  ],
   "scripts": {
     "dev": "concurrently \"npm run dev:mobile\" \"npm run dev:web\" \"npm run dev:nest\"",
     "dev:mobile": "npm run start --workspace=apps/mobile_3 -- --clear",
     "dev:web": "npm run dev --workspace=apps/web_2 --port=3001",
     "dev:nest": "npm run start:dev --workspace=backends/nestjs-fitbattle",
     "dev:backends": "docker-compose up -d",
     "build": "npm run build --workspaces",
     "build:mobile": "npm run build --workspace=apps/mobile_3",
     "build:web": "npm run build --workspace=apps/web_2",
     "test": "npm run test --workspaces",
     "lint": "npm run lint --workspaces",
     "clean": "npm run clean --workspaces && rm -rf node_modules",
     "postinstall": "npm run postinstall --workspaces --if-present",
     "setup": "npm run setup:clean",
     "setup:clean": "powershell -ExecutionPolicy Bypass -File scripts/monorepo-setup.ps1",
     "setup:clean:bash": "bash scripts/monorepo-setup.sh",
     "setup:rebuild": "powershell -ExecutionPolicy Bypass -File scripts/monorepo-setup.ps1 -Force",
     "reset": "npm run setup:rebuild",
     "health": "bash scripts/health-check.sh"
   },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}